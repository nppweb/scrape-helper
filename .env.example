NODE_ENV=development
RABBITMQ_URL=amqp://app:app@localhost:5672
QUEUE_RAW_EVENT=source.raw.v1
QUEUE_QUARANTINE_EVENT=source.raw.quarantine.v1
SCRAPE_SCHEDULE=*/20 * * * *
SHARED_CONTRACTS_DIR=../shared-contracts

S3_ENDPOINT=http://localhost:9000
S3_REGION=ru-central-1
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio12345
S3_BUCKET=artifacts
S3_FORCE_PATH_STYLE=true

ENABLED_SOURCES=demo-source
DEMO_SOURCE_BASE_URL=https://demo-source.local
DEMO_SOURCE_ITEM_COUNT=2

FIND_TENDER_API_URL=https://www.find-tender.service.gov.uk/api/1.0/ocdsReleasePackages?limit=5
EASUZ_BASE_URL=https://easuz.mosreg.ru
EASUZ_SEARCH_URL=https://easuz.mosreg.ru/tenders
EASUZ_MAX_ITEMS=5
EASUZ_USER_AGENT=AIMSORA procurement monitor/1.0 (+https://example.local/aimsora)
FNS_BASE_URL=https://egrul.nalog.ru
FNS_LOOKUP_QUERIES=7707083893
FNS_MAX_ITEMS=3
FNS_USER_AGENT=AIMSORA procurement monitor/1.0 (+https://example.local/aimsora)
FNS_DOWNLOAD_EXTRACT=true
GISTORGI_BASE_URL=https://torgi.gov.ru
GISTORGI_SEARCH_URL=https://torgi.gov.ru/new/public/lots/search
GISTORGI_MAX_ITEMS=5
GISTORGI_USER_AGENT=AIMSORA procurement monitor/1.0 (+https://example.local/aimsora)
FEDRESURS_BASE_URL=https://bankrot.fedresurs.ru
FEDRESURS_SEARCH_URL=https://bankrot.fedresurs.ru/Messages.aspx
FEDRESURS_MAX_ITEMS=5
FEDRESURS_USER_AGENT=AIMSORA procurement monitor/1.0 (+https://example.local/aimsora)
EIS_BASE_URL=https://zakupki.gov.ru
EIS_SEARCH_URL=https://zakupki.gov.ru/epz/order/extendedsearch/results.html?searchString=&morphology=on&sortDirection=false&recordsPerPage=_10&showLotsInfoHidden=false
EIS_MAX_ITEMS=5
EIS_USER_AGENT=AIMSORA procurement monitor/1.0 (+https://example.local/aimsora)
RNP_BASE_URL=https://zakupki.gov.ru
RNP_SEARCH_URL=https://zakupki.gov.ru/epz/dishonestsupplier/search/results.html?searchString=&recordsPerPage=_10
RNP_MAX_ITEMS=5
RNP_USER_AGENT=AIMSORA procurement monitor/1.0 (+https://example.local/aimsora)
REQUEST_TIMEOUT_MS=15000
RETRY_ATTEMPTS=3
RETRY_BASE_DELAY_MS=1000
CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
CIRCUIT_BREAKER_OPEN_MS=600000

# Optional proxy vars for environments where outbound HTTP must go through a proxy
