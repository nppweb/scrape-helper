{
  "name": "scraper-service",
  "version": "0.1.0",
  "private": true,
  "description": "Черновой сервис сбора данных из открытых источников.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "amqplib": "^0.10.5",
    "dotenv": "^16.4.7",
    "node-cron": "^3.0.3",
    "playwright": "^1.49.1"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.7",
    "@types/node": "^22.10.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
